# Copy this file to .env and fill in your own keys before running --live mode.
# Static mode (python run_pipeline.py, no flags) needs NONE of these.

# Required for agents/discover.py and agents/crawler.py (live doc search + scraping)
FIRECRAWL_API_KEY=

# Required for agents/extractor.py (structured extraction from crawled docs)
ANTHROPIC_API_KEY=

# Optional: only needed if you wire Composio's own SDK/MCP tool-calling into
# discover.py or extractor.py instead of the raw httpx calls used by default
COMPOSIO_API_KEY=

# Optional: fallback extraction model if you swap extractor.py to use OpenAI instead of Claude
OPENAI_API_KEY=
